#!/data/data/com.termux/files/usr/bin/bash

# ==============================================
#  SillyTavern Termux 全功能控制面板
#  功能：安装 · 启动 · 停止 · 日志 · 重启
# ==============================================

# ✅ 修复1：不覆盖系统 $HOME，改用独立变量
TERMUX_HOME="/data/data/com.termux/files/home"
TAVERN="$TERMUX_HOME/SillyTavern"
LOG="$TAVERN/tavern.log"
PID_FILE="$TAVERN/.tavern.pid"
BACKUP_DIR="$TERMUX_HOME/SillyTavern_backup"

# --- 颜色 ---
GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${BLUE}[*] $1${NC}"; }
ok()    { echo -e "${GREEN}[+] $1${NC}"; }
err()   { echo -e "${RED}[!] $1${NC}"; }
warn()  { echo -e "${YELLOW}[!] $1${NC}"; }
has()   { command -v "$1" >/dev/null 2>&1; }

# ==============================================
#  ✅ 修复2：npm 镜像 - 用 curl 实测连通性再设置
# ==============================================
pick_npm_mirror() {
    local mirrors=(
        "https://registry.npmmirror.com"
        "https://mirrors.cloud.tencent.com/npm/"
        "https://mirrors.huaweicloud.com/repository/npm/"
        "https://registry.npmjs.org"
    )
    info "检测最快 npm 镜像..."
    for m in "${mirrors[@]}"; do
        if curl -sf --max-time 6 "$m" >/dev/null 2>&1; then
            npm config set registry "$m"
            ok "npm 镜像已设置: $m"
            return 0
        fi
        warn "不可达: $m"
    done
    err "所有 npm 镜像均不可达，使用默认源"
    return 1
}

# ==============================================
#  安装依赖（Node.js + Git）
# ==============================================
install_deps() {
    info "更新软件源..."
    pkg update -y

    info "安装 Node.js 和 Git..."
    pkg install -y nodejs git

    pick_npm_mirror
}

# ==============================================
#  ✅ 修复3：Git 镜像 - 移除已知失效源，补充可用加速源
# ==============================================
clone_tavern() {
    local target="$1"
    local repo_path="SillyTavern/SillyTavern.git"

    local mirrors=(
        "https://gitee.com/mirrors/SillyTavern.git"
        "https://mirror.ghproxy.com/https://github.com/$repo_path"
        "https://ghfast.top/https://github.com/$repo_path"
        "https://gh-proxy.com/https://github.com/$repo_path"
        "https://github.com/$repo_path"
    )

    for url in "${mirrors[@]}"; do
        info "尝试克隆: $url"
        if git clone --depth=1 "$url" "$target"; then
            ok "克隆成功"
            return 0
        else
            warn "该源失败，尝试下一个..."
            rm -rf "$target" 2>/dev/null
        fi
    done

    err "所有镜像均克隆失败，请检查网络"
    return 1
}

# ==============================================
#  端口占用检测
# ==============================================
check_port() {
    local port="${1:-8000}"
    # 优先用 ss，没有则用 netstat
    if has ss; then
        ss -tlnp 2>/dev/null | grep -q ":$port "
    elif has netstat; then
        netstat -tlnp 2>/dev/null | grep -q ":$port "
    else
        # 兜底：尝试 TCP 连接
        (echo >/dev/tcp/127.0.0.1/$port) 2>/dev/null
    fi
}

# ==============================================
#  重装前备份用户数据
# ==============================================
backup_data() {
    local stamp
    stamp=$(date +%Y%m%d_%H%M%S)
    local dest="$BACKUP_DIR/$stamp"

    # 需要备份的目录/文件（相对于 $TAVERN）
    local targets=(
        "public/characters"
        "public/chats"
        "public/user"
        "public/backgrounds"
        "public/groups"
        "config.yaml"
        "settings.json"
    )

    local found=0
    for t in "${targets[@]}"; do
        [ -e "$TAVERN/$t" ] && found=1 && break
    done

    if [ "$found" -eq 0 ]; then
        info "未发现用户数据，跳过备份"
        return 0
    fi

    info "备份用户数据到: $dest"
    mkdir -p "$dest"

    for t in "${targets[@]}"; do
        if [ -e "$TAVERN/$t" ]; then
            local parent
            parent=$(dirname "$t")
            mkdir -p "$dest/$parent"
            cp -r "$TAVERN/$t" "$dest/$parent/" && info "  ✔ $t"
        fi
    done

    ok "备份完成 → $dest"
}

# ==============================================
#  更新 SillyTavern（保留用户数据）
# ==============================================
update_tavern() {
    clear
    echo "======================================"
    echo "     更新 SillyTavern"
    echo "======================================"

    if [ ! -d "$TAVERN" ]; then
        err "未检测到 SillyTavern，请先安装"
        return 1
    fi

    local was_running=0
    if is_running; then
        warn "酒馆正在运行，更新前将自动停止"
        stop_tavern
        was_running=1
    fi

    cd "$TAVERN" || return 1

    info "拉取最新代码..."
    if ! git pull; then
        err "git pull 失败，请检查网络或手动处理"
        [ "$was_running" -eq 1 ] && start_tavern
        return 1
    fi

    info "更新 npm 依赖..."
    npm install --no-optional || warn "部分依赖更新失败，可能不影响运行"

    ok "🎉 更新完成！"

    if [ "$was_running" -eq 1 ]; then
        read -p "是否立即重新启动？(Y/n): " yn
        [[ ! "$yn" =~ ^[Nn]$ ]] && start_tavern
    fi
}

# ==============================================
#  安装/重装 SillyTavern
# ==============================================
install_tavern() {
    clear
    echo "======================================"
    echo "     安装 SillyTavern"
    echo "======================================"

    install_deps

    if [ -d "$TAVERN" ]; then
        warn "已存在旧版本目录"
        read -p "是否删除并重新安装？(y/N): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            backup_data
            rm -rf "$TAVERN"
            ok "旧目录已删除"
        else
            ok "保留现有目录，跳过安装"
            return
        fi
    fi

    clone_tavern "$TAVERN" || {
        err "克隆失败，终止安装"
        return 1
    }

    cd "$TAVERN" || return 1

    info "安装 npm 依赖（可能需要几分钟）..."
    if npm install --no-optional; then
        ok "依赖安装完成"
    else
        warn "部分依赖安装失败，尝试修复..."
        npm install || {
            err "依赖修复失败，请手动处理"
            return 1
        }
    fi

    echo ""
    ok "🎉 SillyTavern 安装成功！"
    echo "访问地址: http://localhost:8000"
    sleep 2
}

# ==============================================
#  ✅ 修复4：进程管理 - 用 PID 文件替代 pgrep 模糊匹配
# ==============================================
is_running() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        kill -0 "$pid" 2>/dev/null && return 0
    fi
    # 兼容旧方式兜底
    pgrep -f "node.*server.js" >/dev/null 2>&1
}

# ==============================================
#  启动酒馆
# ==============================================
start_tavern() {
    if [ ! -d "$TAVERN" ]; then
        err "未检测到 SillyTavern"
        read -p "是否立即安装？(y/N): " yn
        if [[ "$yn" =~ ^[Yy]$ ]]; then
            install_tavern
            [ ! -d "$TAVERN" ] && return
        else
            return
        fi
    fi

    if is_running; then
        warn "酒馆已在运行中"
        return
    fi

    if check_port 8000; then
        err "端口 8000 已被其他进程占用，无法启动"
        warn "可用 'ss -tlnp | grep 8000' 查看占用进程"
        return 1
    fi

    cd "$TAVERN" || return
    info "正在启动 SillyTavern..."

    # ✅ 修复5：添加 disown，防止关闭 Termux 会话后进程被杀
    nohup node server.js > "$LOG" 2>&1 &
    echo $! > "$PID_FILE"
    disown

    sleep 3

    if is_running; then
        ok "启动成功 🚀  (PID: $(cat "$PID_FILE"))"
        echo "地址: http://localhost:8000"
        has termux-open-url && termux-open-url http://localhost:8000
    else
        rm -f "$PID_FILE"
        err "启动失败，最后10行日志:"
        tail -n 10 "$LOG" 2>/dev/null
    fi
}

# ==============================================
#  停止酒馆
# ==============================================
stop_tavern() {
    if is_running; then
        info "正在停止..."
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")" 2>/dev/null
            rm -f "$PID_FILE"
        else
            pkill -f "node.*server.js"
        fi
        sleep 1
        ok "已停止"
    else
        warn "酒馆未运行"
    fi
}

# ==============================================
#  重启酒馆
# ==============================================
restart_tavern() {
    stop_tavern
    sleep 1
    start_tavern
}

# ==============================================
#  查看状态
# ==============================================
status_tavern() {
    if is_running; then
        local pid=""
        [ -f "$PID_FILE" ] && pid=" | PID: $(cat "$PID_FILE")"
        echo -e "${GREEN}● 运行中${NC}$pid"
    else
        echo -e "${RED}● 已停止${NC}"
    fi
}

# ==============================================
#  查看日志
# ==============================================
view_log() {
    if [ ! -f "$LOG" ]; then
        err "日志文件不存在"
        sleep 1
        return
    fi

    clear
    echo "日志查看方式:"
    echo " 1. 实时滚动"
    echo " 2. 最后50行"
    echo " 0. 返回"
    read -p "选择: " c
    case $c in
        1)
           echo "（按 Ctrl+C 返回菜单）"
           trap 'echo ""; return' INT
           tail -f "$LOG"
           trap - INT
           ;;
        2) tail -n 50 "$LOG" ; echo "" ; read -p "按回车继续..." ;;
        0) return ;;
        *) err "无效" ; sleep 1 ;;
    esac
}

# ==============================================
#  主菜单
# ==============================================
menu() {
    while true; do
        clear
        echo "======================================"
        echo "   SillyTavern 控制面板 (Termux)"
        echo "======================================"
        echo -n " 状态: "; status_tavern
        echo "======================================"
        echo " 1. 启动酒馆"
        echo " 2. 停止酒馆"
        echo " 3. 重启酒馆"
        echo " 4. 安装 / 重装"
        echo " 5. 更新酒馆"
        echo " 6. 查看日志"
        echo " 0. 退出"
        echo "======================================"
        read -p "请输入选项: " choice

        case $choice in
            1) start_tavern ;;
            2) stop_tavern ;;
            3) restart_tavern ;;
            4) install_tavern ;;
            5) update_tavern ;;
            6) view_log ;;
            0) echo "再见！"; exit 0 ;;
            *) err "无效选项"; sleep 1 ;;
        esac

        echo ""
        read -p "按回车返回菜单..."
    done
}

# ==============================================
#  入口：支持命令行快捷参数
# ==============================================
case "$1" in
    start)   start_tavern ;;
    stop)    stop_tavern ;;
    restart) restart_tavern ;;
    install) install_tavern ;;
    update)  update_tavern ;;
    log)     view_log ;;
    status)  status_tavern ;;
    *)       menu ;;
esac
